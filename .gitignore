# dependencies
node_modules/

# build output
dist/

# overreach runtime: scope cache (per-prompt extracted scopes) + raw harness data
.overreach/
overreach-model-results.json

# secrets — Overreach reads keys only from the process env (sourced inline at
# runtime); no .env should ever live in this repo.
.env
.env.*
!.env.example

# logs / OS cruft
*.log
.DS_Store
Thumbs.db

# launch / distribution kit — kept locally, not published to the repo
site/LAUNCH-DISTRIBUTION.md
# wrangler local dev cache (miniflare D1)
.wrangler/

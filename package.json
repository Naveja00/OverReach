{
  "name": "overreach",
  "version": "0.7.0",
  "description": "AI PR review assistant. Checks what your AI agent actually changed vs what you asked for. Deterministic, evidence-backed, no AI opinions.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "overreach": "dist/src/cli.js",
    "overreach-server": "dist/src/index.js",
    "overreach-cli": "dist/src/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai-review",
    "pr-review",
    "code-review",
    "ai-coding",
    "scope-creep",
    "claude",
    "cursor",
    "copilot",
    "codex",
    "windsurf",
    "mcp",
    "diff",
    "ci"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "tsx tests/run.ts",
    "test:edge": "tsx tests/edge_and_smuggle.ts",
    "test:e2e": "tsx tests/e2e_ollama.ts",
    "simulate": "tsx tests/simulate.ts",
    "simulate:large": "tsx tests/simulate_large.ts",
    "simulate:stress": "tsx tests/simulate_stress.ts",
    "simulate:false-denial": "tsx tests/simulate_false_denial.ts",
    "harness": "tsx tests/multi_model.ts",
    "cli": "tsx src/cli.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@anthropic-ai/sdk": "^0.32.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}

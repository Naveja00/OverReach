diff --git a/sections/product-size-chart.liquid b/sections/product-size-chart.liquid
new file mode 100644
--- /dev/null
+++ b/sections/product-size-chart.liquid
@@ -0,0 +1,47 @@
+<div class="size-chart-trigger" data-product="{{ product.handle }}">
+  <button class="size-chart__btn" aria-expanded="false">
+    <svg width="16" height="16" viewBox="0 0 16 16"><path d="M2 14h12V2H2v12zM4 4h2v2H4V4zm4 0h2v2H8V4z"/></svg>
+    Size Guide
+  </button>
+</div>
+
+<div class="size-chart-modal" id="size-chart-{{ section.id }}" aria-hidden="true">
+  <div class="size-chart-modal__overlay" data-close-modal></div>
+  <div class="size-chart-modal__content">
+    <button class="size-chart-modal__close" data-close-modal aria-label="Close">&times;</button>
+    <h2 class="size-chart-modal__title">{{ product.metafields.custom.size_chart_title | default: "Size Guide" }}</h2>
+    <table class="size-chart__table">
+      <thead>
+        <tr>
+          <th>Size</th><th>Chest (in)</th><th>Waist (in)</th><th>Length (in)</th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for row in product.metafields.custom.size_chart_data.value %}
+        <tr>
+          <td>{{ row.size }}</td><td>{{ row.chest }}</td><td>{{ row.waist }}</td><td>{{ row.length }}</td>
+        </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  </div>
+</div>
+
+{% schema %}
+{
+  "name": "Size Chart",
+  "settings": [
+    { "type": "checkbox", "id": "show_on_all", "label": "Show on all products", "default": true }
+  ]
+}
+{% endschema %}
diff --git a/assets/size-chart.js b/assets/size-chart.js
new file mode 100644
--- /dev/null
+++ b/assets/size-chart.js
@@ -0,0 +1,18 @@
+document.addEventListener("DOMContentLoaded", () => {
+  document.querySelectorAll(".size-chart__btn").forEach(btn => {
+    btn.addEventListener("click", () => {
+      const modal = btn.closest("section").querySelector(".size-chart-modal");
+      modal.setAttribute("aria-hidden", "false");
+      document.body.style.overflow = "hidden";
+    });
+  });
+  document.querySelectorAll("[data-close-modal]").forEach(el => {
+    el.addEventListener("click", () => {
+      el.closest(".size-chart-modal").setAttribute("aria-hidden", "true");
+      document.body.style.overflow = "";
+    });
+  });
+});
diff --git a/snippets/product-reviews.liquid b/snippets/product-reviews.liquid
new file mode 100644
--- /dev/null
+++ b/snippets/product-reviews.liquid
@@ -0,0 +1,22 @@
+<div class="product-reviews" data-product-id="{{ product.id }}">
+  <h3>Customer Reviews</h3>
+  <div class="reviews-summary">
+    <span class="reviews-average">{{ product.metafields.reviews.average | default: "No reviews yet" }}</span>
+  </div>
+  <div id="review-list"></div>
+  <form class="review-form" action="/apps/reviews/submit" method="POST">
+    <input type="hidden" name="product_id" value="{{ product.id }}">
+    <textarea name="body" placeholder="Write your review..." required></textarea>
+    <select name="rating"><option value="5">★★★★★</option><option value="4">★★★★</option><option value="3">★★★</option></select>
+    <button type="submit">Submit Review</button>
+  </form>
+</div>
diff --git a/snippets/inventory-alert.liquid b/snippets/inventory-alert.liquid
new file mode 100644
--- /dev/null
+++ b/snippets/inventory-alert.liquid
@@ -0,0 +1,14 @@
+{% if product.variants.first.inventory_quantity < 5 and product.variants.first.inventory_quantity > 0 %}
+<div class="inventory-alert">
+  <p>Only {{ product.variants.first.inventory_quantity }} left in stock!</p>
+</div>
+{% endif %}
+{% if product.variants.first.inventory_quantity == 0 %}
+<div class="inventory-alert inventory-alert--soldout">
+  <form class="notify-form" action="/apps/notify/subscribe" method="POST">
+    <input type="hidden" name="product_id" value="{{ product.id }}">
+    <input type="email" name="email" placeholder="Email when back in stock" required>
+    <button type="submit">Notify Me</button>
+  </form>
+</div>
+{% endif %}
diff --git a/assets/analytics-events.js b/assets/analytics-events.js
new file mode 100644
--- /dev/null
+++ b/assets/analytics-events.js
@@ -0,0 +1,12 @@
+window.addEventListener("DOMContentLoaded", () => {
+  if (typeof gtag === "function") {
+    gtag("event", "view_item", {
+      currency: Shopify.currency.active,
+      value: parseFloat(document.querySelector("[data-product-price]")?.textContent || "0"),
+      items: [{ item_id: window.meta?.product?.id, item_name: window.meta?.product?.title }]
+    });
+  }
+  document.querySelectorAll(".size-chart__btn").forEach(btn => {
+    btn.addEventListener("click", () => gtag("event", "size_chart_opened"));
+  });
+});

@@ -0,0 +1,15 @@
+import { formatDate, formatCurrency } from "../format";
+
+describe("formatDate", () => {
+  it("formats dates", () => {
+    const d = new Date("2026-01-15");
+    expect(formatDate(d)).toContain("2026");
+  });
+});
+
+describe("formatCurrency", () => {
+  it("formats USD", () => {
+    expect(formatCurrency(9.99, "USD")).toBe("$9.99");
+  });
+});

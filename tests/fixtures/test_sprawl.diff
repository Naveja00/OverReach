diff --git a/src/utils/__tests__/validate.test.ts b/src/utils/__tests__/validate.test.ts
new file mode 100644
--- /dev/null
+++ b/src/utils/__tests__/validate.test.ts
@@ -0,0 +1,22 @@
+import { validateEmail } from "../validate";
+
+describe("validateEmail", () => {
+  it("accepts valid emails", () => {
+    expect(validateEmail("user@example.com")).toBe(true);
+    expect(validateEmail("first.last@domain.co.uk")).toBe(true);
+  });
+
+  it("rejects invalid emails", () => {
+    expect(validateEmail("")).toBe(false);
+    expect(validateEmail("no-at-sign")).toBe(false);
+    expect(validateEmail("@no-local")).toBe(false);
+  });
+});
